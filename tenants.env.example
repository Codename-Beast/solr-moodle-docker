# =========================================
# Solr Multi-Tenant Configuration
# =========================================
# This file is managed by solr-tenant.sh — do not edit manually.
# Copy to tenants.env to pre-seed tenants (passwords must be plain text on first run).
#
# Manage tenants:
#   docker exec solr /opt/solr/scripts/solr-tenant.sh create <name> --cores <core1>[,<core2>]
#   docker exec solr /opt/solr/scripts/solr-tenant.sh list
#   docker exec solr /opt/solr/scripts/solr-tenant.sh --help

# Format:
# TENANT_<name>_CORES=<core1>[,<core2>]
# TENANT_<name>_USER=solr_<name>
# TENANT_<name>_PASS=<auto_generated_32char_password>
# TENANT_<name>_ACTIVE=true|false

# Example — School A (two cores: production + test):
# TENANT_schule_a_CORES=moodle_prod_a,moodle_test_a
# TENANT_schule_a_USER=solr_schule_a
# TENANT_schule_a_PASS=CHANGE_ME_OR_LET_SYSTEM_GENERATE
# TENANT_schule_a_ACTIVE=true

# Example — School B (one core):
# TENANT_schule_b_CORES=moodle_prod_b
# TENANT_schule_b_USER=solr_schule_b
# TENANT_schule_b_PASS=CHANGE_ME_OR_LET_SYSTEM_GENERATE
# TENANT_schule_b_ACTIVE=true
