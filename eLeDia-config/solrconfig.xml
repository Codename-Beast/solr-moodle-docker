<?xml version="1.0" encoding="UTF-8" ?>
<!--
  Solr Configuration for Moodle 4.0 - 5.0.3
  Author: BSC (Bernd Schreistetter)

  Optimized for:
  - Moodle Global Search with File-Indexing
  - Fast indexing and search response
  - Memory-efficient caching
  - Auto-commit for real-time updates

  Supports ManagedIndexSchemaFactory for Moodle Schema API
-->
<config>
  <!-- Lucene Match Version -->
  <luceneMatchVersion>9.10.0</luceneMatchVersion>

  <!-- Data Directory -->
  <dataDir>${solr.data.dir:}</dataDir>

  <!-- Directory Factory -->
  <directoryFactory name="DirectoryFactory" class="${solr.directoryFactory:solr.NRTCachingDirectoryFactory}"/>

  <!-- Schema Factory - Managed Schema for Moodle Schema API -->
  <!--
    Using ManagedIndexSchemaFactory for Moodle compatibility:
    - Moodle uses Schema API to add/validate fields via setup_schema.php
    - Required endpoint: /solr/{core}/schema
    - mutable=true allows Moodle to add fields if needed
    - Pre-populated managed-schema has all required Moodle fields
    - Dynamic field additions are supported for future Moodle versions
  -->
  <schemaFactory class="ManagedIndexSchemaFactory">
    <bool name="mutable">true</bool>
    <str name="managedSchemaResourceName">managed-schema</str>
  </schemaFactory>


  <!-- Index Configuration -->
  <indexConfig>
    <!-- RAM Buffer Size: Single-Core default -->
    <ramBufferSizeMB>100</ramBufferSizeMB>
    <maxBufferedDocs>1000</maxBufferedDocs>
    <useCompoundFile>false</useCompoundFile>
    <mergePolicyFactory class="org.apache.solr.index.TieredMergePolicyFactory">
      <int name="maxMergeAtOnce">10</int>
      <int name="segmentsPerTier">10</int>
    </mergePolicyFactory>
    <mergeScheduler class="org.apache.lucene.index.ConcurrentMergeScheduler"/>
    <lockType>${solr.lock.type:native}</lockType>
    <writeLockTimeout>1000</writeLockTimeout>
  </indexConfig>

  <!-- Update Handler -->
  <updateHandler class="solr.DirectUpdateHandler2">
    <updateLog>
      <str name="dir">${solr.ulog.dir:}</str>
    </updateLog>

    <!-- Auto Commit - Optimized for Moodle -->
    <autoCommit>
      <maxTime>${solr.autoCommit.maxTime:15000}</maxTime>
      <maxDocs>1000</maxDocs>
      <openSearcher>false</openSearcher>
    </autoCommit>

    <!-- Auto Soft Commit - For near real-time search -->
    <autoSoftCommit>
      <maxTime>${solr.autoSoftCommit.maxTime:1000}</maxTime>
    </autoSoftCommit>
  </updateHandler>

  <!-- Query Configuration -->
  <query>
    <maxBooleanClauses>${solr.max.booleanClauses:1024}</maxBooleanClauses>

    <!-- Cache Configuration
         Sizes are controlled via Solr system properties (-D flags in SOLR_OPTS).
         Ansible variable solr_filter_cache_size  → -Dsolr.filterCache.size=N
         Ansible variable solr_query_cache_size   → -Dsolr.queryResultCache.size=N
         Ansible variable solr_document_cache_size → -Dsolr.documentCache.size=N
         Defaults (512) are suitable for single-core with 2g heap.
         Multi-core: reduce per-core values (e.g. 256) to share heap. -->
    <filterCache class="solr.CaffeineCache"
                 size="${solr.filterCache.size:512}"
                 initialSize="${solr.filterCache.size:512}"
                 autowarmCount="128"/>
    <queryResultCache class="solr.CaffeineCache"
                      size="${solr.queryResultCache.size:512}"
                      initialSize="${solr.queryResultCache.size:512}"
                      autowarmCount="128"/>
    <documentCache class="solr.CaffeineCache"
                   size="${solr.documentCache.size:512}"
                   initialSize="${solr.documentCache.size:512}"
                   autowarmCount="0"/>
    <cache name="perSegFilter"
           class="solr.CaffeineCache"
           size="10"
           initialSize="0"
           autowarmCount="10"/>
    <enableLazyFieldLoading>true</enableLazyFieldLoading>
    <queryResultWindowSize>20</queryResultWindowSize>
    <queryResultMaxDocsCached>200</queryResultMaxDocsCached>
    <useColdSearcher>false</useColdSearcher>
  </query>

  <!-- Request Dispatcher -->
  <requestDispatcher>
    <!-- Upload limits are configurable via JVM system properties (SOLR_OPTS):
         -Dsolr.multipartUploadLimitKB=102400   (default 100 MB)
         -Dsolr.formdataUploadLimitKB=2048      (default 2 MB)
         Keep limits tight to reduce DoS risk from oversized uploads. -->
    <requestParsers multipartUploadLimitInKB="${solr.multipartUploadLimitKB:102400}"
                    formdataUploadLimitInKB="${solr.formdataUploadLimitKB:2048}"
                    addHttpRequestToContext="false"/>
    <httpCaching never304="true"/>
  </requestDispatcher>

  <!-- Request Handlers -->

  <!-- Standard Request Handler -->
  <requestHandler name="/select" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="echoParams">explicit</str>
      <int name="rows">10</int>
      <str name="df">content</str>
      <str name="wt">json</str>
      <str name="indent">true</str>
    </lst>
  </requestHandler>

  <!-- Update Request Handler -->
  <requestHandler name="/update" class="solr.UpdateRequestHandler"/>

  <!-- Moodle-specific Search Handler for diagnostics/custom probes.
       Moodle core search_solr normally builds its own /select queries. This handler
       is kept as an optimized, testable profile for operator checks and external probes. -->
  <requestHandler name="/moodle" class="solr.SearchHandler">
    <lst name="defaults">
      <str name="echoParams">explicit</str>
      <str name="wt">json</str>
      <str name="indent">true</str>
      <str name="defType">edismax</str>
      <str name="df">content</str>
      <int name="rows">10</int>
      <str name="q.op">AND</str>
      <str name="qf">title^5.0 content^2.0 description1^1.5 description2^1.2 intro^1.2 solr_filecontent^1.0</str>
      <str name="pf">title^10.0 content^5.0 solr_filecontent^3.0</str>
      <int name="ps">3</int>
      <str name="mm">2&lt;-1 5&lt;-2 6&lt;90%</str>
      <bool name="lowercaseOperators">true</bool>
    </lst>
  </requestHandler>

  <!-- Admin Handlers -->
  <requestHandler name="/admin/ping" class="solr.PingRequestHandler">
    <!-- Moodle may call /admin/ping?action=enable; Solr requires healthcheckFile. -->
    <str name="healthcheckFile">${solr.ping.healthcheckFile:/var/solr/data/healthcheck/ping-enabled.txt}</str>
    <lst name="invariants">
      <str name="q">solrpingquery</str>
    </lst>
    <lst name="defaults">
      <str name="echoParams">all</str>
    </lst>
  </requestHandler>

  <!-- Schema API Handler -->
  <requestHandler name="/schema" class="solr.SchemaHandler">
    <lst name="defaults">
      <str name="df">content</str>
    </lst>
  </requestHandler>

  <!-- Tika file extraction for Moodle file indexing (Moodle calls /update/extract) -->
  <requestHandler name="/update/extract" class="solr.extraction.ExtractingRequestHandler" startup="lazy">
    <lst name="defaults">
      <!-- Hardened defaults for Moodle file indexing -->
      <str name="lowernames">true</str>
      <str name="uprefix">ignored_</str>
      <str name="captureAttr">false</str>
      <!-- Keep literal.* metadata authoritative for Moodle-required fields (id, contextid, etc.). -->
      <str name="literalsOverride">true</str>
      <!-- Map extracted body text to Moodle's canonical searchable field. -->
      <str name="fmap.content">content</str>
      <str name="fmap.a">links</str>
      <str name="fmap.div">ignored_</str>
    </lst>
    <str name="defaultField">solr_filecontent</str>
  </requestHandler>

  <!-- Analysis Request Handler -->
  <requestHandler name="/analysis/field"
                  startup="lazy"
                  class="solr.FieldAnalysisRequestHandler"/>

  <!-- Admin Request Handler -->
  <admin>
    <defaultQuery>*:*</defaultQuery>
  </admin>

</config>
