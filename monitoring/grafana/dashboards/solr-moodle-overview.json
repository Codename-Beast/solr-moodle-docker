{
  "uid": "solr-moodle",
  "title": "Solr (Moodle) - Overview",
  "tags": ["solr", "moodle", "prometheus"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "panels": [
    {
      "type": "stat",
      "title": "Target Up (Solr)",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "targets": [{ "expr": "up{job=\"solr\"}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Scrape Duration (s)",
      "gridPos": { "x": 6, "y": 0, "w": 18, "h": 8 },
      "targets": [{ "expr": "scrape_duration_seconds{job=\"solr\"}", "refId": "A" }]
    },
    {
      "type": "timeseries",
      "title": "Samples Scraped",
      "gridPos": { "x": 0, "y": 8, "w": 24, "h": 8 },
      "targets": [{ "expr": "scrape_samples_scraped{job=\"solr\"}", "refId": "A" }]
    }
  ]
}
