# =========================================
# Solr for Moodle - Environment Configuration
# =========================================
# Copy this file to .env and adjust the values
# Or run: ./setup.sh  (interactive, auto-generates passwords)

# Instance Configuration
INSTANCE_NAME=solr
SOLR_HOSTNAME=solr.example.com

# Stack / Solr Configuration
# STACK_VERSION controls the init image tag; keep it aligned with CHANGELOG.md.
STACK_VERSION=v3.4.10
SOLR_VERSION=9.10.1
SOLR_PORT=8983
SOLR_BIND=127.0.0.1
SOLR_HEAP=2g
SOLR_LOG_LEVEL=ERROR
# Solr 9.10: graceful Jetty shutdown verhindert harte Client-Abbrüche
SOLR_JETTY_GRACEFUL=true
# Request-Logs standardmäßig aus (reduziert Warn-Noise; bei Bedarf auf true setzen)
SOLR_LOGS_REQUESTLOG_ENABLED=false
# Solr-Module (extraction wird für Moodle-Dateiindexierung benötigt)
SOLR_MODULES=extraction
# Optional: Environment-Banner in Solr Admin UI
SOLR_ENVIRONMENT=prod,label=Production,color=red
# Optional zusätzliche JVM/System-Properties
SOLR_JAVA_OPTS=
# Java Security Manager deaktiviert (vermeidet JVM-Deprecation-Warnungen auf Java 21+)
SOLR_SECURITY_MANAGER_ENABLED=false

# Deployment Mode
# SolrCloud is default in v3.4.10.
# Leave as 'solrcloud' unless you have a legacy migration reason.
SOLR_MODE=solrcloud

# Host log root for all Docker runtime/setup/install/init logs
# Effective path: ${ELEDIA_LOG_ROOT}/${INSTANCE_NAME}
ELEDIA_LOG_ROOT=/var/log/eledia/solr

# Optional multi-target metadata for the global init container
# Comma-separated runtime targets (used for orchestration docs/logging)
INIT_TARGETS=solr-a,solr-b,solr-c

# Network
SOLR_NETWORK_NAME=solr_network

# Solr System Users (CHANGE THESE PASSWORDS!)
# Generate: openssl rand -base64 36 | tr -d '/+=' | head -c 32
SOLR_ADMIN_USER=admin
SOLR_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
SOLR_SUPPORT_USER=support
SOLR_SUPPORT_PASSWORD=CHANGE_ME_SUPPORT_PASSWORD
# Tenant users are managed via: docker exec solr /opt/solr/scripts/solr-tenant.sh
# Optional: override tenant SOT path inside the container (mainly for Docker-in-Docker CI)
TENANTS_ENV=/opt/solr/tenants.env

# Resource Limits (optional, defaults used if not set)
SOLR_CPU_LIMIT=2
SOLR_MEMORY_LIMIT=4G
SOLR_CPU_RESERVATION=0.5
SOLR_MEMORY_RESERVATION=2G

# =========================================
# Optional: Documentation (not used in code)
# =========================================
# CUSTOMER_NAME=<customer name for admin reference>
# NOTES=<additional notes>
